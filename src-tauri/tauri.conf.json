{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dr.SheetSplit",
  "version": "1.0.7",
  "identifier": "com.west.drsheetsplit",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Dr.SheetSplit",
        "width": 1040,
        "height": 720,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 16
        },
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "python/transform_engine.py",
      "python/engine",
      "python/runtime"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/AppIcon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/westng/Dr.SheetSplit/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDMDg3NkYwODhCNTlGOEUKUldTT243V0k4SFlJVFBSeUsxTTROMzNiSW5uTjJmS1RLZTRqcEg0dDMwQ2pUbWE2TTBkSW5COE0K"
    }
  }
}
